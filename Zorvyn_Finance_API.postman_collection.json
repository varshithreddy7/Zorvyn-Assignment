{
	"info": {
		"name": "Zorvyn Finance Data API",
		"description": "API collection for Zorvyn Backend Assignment. Pre-configured with automatic JWT token management (login automatically saves token).",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
		"_exporter_id": "0"
	},
	"item": [
		{
			"name": "1. Authentication",
			"item": [
				{
					"name": "Register User",
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"Test Analyst\",\n  \"email\": \"test.analyst@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"analyst\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/auth/register",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"auth",
								"register"
							]
						}
					},
					"response": []
				},
				{
					"name": "Login (Sets Token Automatically)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if(jsonData.success && jsonData.data.token){",
									"    pm.collectionVariables.set(\"authToken\", jsonData.data.token);",
									"    console.log(\"Saved JWT to Collection Variable.\");",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"admin@zorvyn.com\",\n  \"password\": \"password123\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/auth/login",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"auth",
								"login"
							]
						}
					},
					"response": []
				}
			]
		},
		{
			"name": "2. Dashboard (Viewer/Analyst/Admin)",
			"item": [
				{
					"name": "Get Summary Analytics",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/dashboard/summary",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"dashboard",
								"summary"
							]
						}
					},
					"response": []
				}
			]
		},
		{
			"name": "3. Financial Records",
			"item": [
				{
					"name": "Get All Records (With Filters)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/records?page=1&limit=10",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"records"
							],
							"query": [
								{
									"key": "page",
									"value": "1"
								},
								{
									"key": "limit",
									"value": "10"
								},
								{
									"key": "type",
									"value": "income",
									"disabled": true
								},
								{
									"key": "category",
									"value": "Salary",
									"disabled": true
								}
							]
						}
					},
					"response": []
				},
				{
					"name": "Get Single Record",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/records/1",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"records",
								"1"
							]
						}
					},
					"response": []
				},
				{
					"name": "Create Record (Admin)",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"amount\": 850.50,\n  \"type\": \"expense\",\n  \"category\": \"Marketing\",\n  \"date\": \"2026-04-05T00:00:00Z\",\n  \"notes\": \"Google Ads campaign\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/records",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"records"
							]
						}
					},
					"response": []
				},
				{
					"name": "Update Record (Admin)",
					"request": {
						"method": "PUT",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"amount\": 900.00,\n  \"notes\": \"Increased Google Ads budget\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/records/1",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"records",
								"1"
							]
						}
					},
					"response": []
				},
				{
					"name": "Delete Record (Soft Delete)",
					"request": {
						"method": "DELETE",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/records/1",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"records",
								"1"
							]
						}
					},
					"response": []
				}
			]
		},
		{
			"name": "4. User Management (Admin Only)",
			"item": [
				{
					"name": "Get All Users",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/users",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"users"
							]
						}
					},
					"response": []
				},
				{
					"name": "Get Single User",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/users/2",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"users",
								"2"
							]
						}
					},
					"response": []
				},
				{
					"name": "Update User Role",
					"request": {
						"method": "PUT",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"role\": \"analyst\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/users/3/role",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"users",
								"3",
								"role"
							]
						}
					},
					"response": []
