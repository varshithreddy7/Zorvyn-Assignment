
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

//  Enums

enum Role {
  viewer
  analyst
  admin
}

enum Status {
  active
  inactive
}

enum RecordType {
  income
  expense
}

//  Models 

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String

  role      Role     @default(viewer)
  status    Status   @default(active)

  records   FinancialRecord[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model FinancialRecord {
  id          Int        @id @default(autoincrement())
  amount      Decimal    @db.Decimal(15, 2)
  type        RecordType
  category    String
  date        DateTime   @db.Date
  notes       String?

  createdBy   User       @relation(fields: [createdById], references: [id])
  createdById Int

  // Soft delete support
  deletedAt   DateTime?

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([type])
  @@index([category])
  @@index([date])
  @@index([deletedAt])
  @@map("financial_records")
}
